{
  "name": "app-humhub",
  "description": "Instala o HumHub (rede social/coworking open-source) como Docker Swarm.",
  "depends_on": [
    "infra-bootstrap",
    "app-traefik",
    "infra-mysql"
  ],
  "required_inputs": [
    {
      "name": "DOMAIN_HUMHUB",
      "description": "Dom\u00ednio para o HumHub (ex: humhub.oriondesign.art.br)",
      "type": "text"
    },
    {
      "name": "HUMHUB_ADMIN_USER",
      "description": "Nome de usu\u00e1rio do admin",
      "type": "text"
    },
    {
      "name": "HUMHUB_ADMIN_EMAIL",
      "description": "Email do admin",
      "type": "text"
    },
    {
      "name": "HUMHUB_ADMIN_PASS",
      "description": "Senha do admin",
      "type": "password"
    },
    {
      "name": "SMTP_FROM_EMAIL",
      "description": "Email remetente",
      "type": "text"
    },
    {
      "name": "SMTP_USER",
      "description": "Usu\u00e1rio SMTP",
      "type": "text"
    },
    {
      "name": "SMTP_PASS",
      "description": "Senha SMTP",
      "type": "password"
    },
    {
      "name": "SMTP_HOST",
      "description": "Host SMTP",
      "type": "text"
    },
    {
      "name": "SMTP_PORT",
      "description": "Porta SMTP",
      "type": "text"
    }
  ],
  "persistence_path": "/root/dados_vps/app-humhub.md",
  "version": "1.0.0"
}
