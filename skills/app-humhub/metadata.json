{
  "name": "app-humhub",
  "description": "Instala o HumHub (rede social/coworking open-source) como Docker Swarm.",
  "depends_on": ["infra-bootstrap", "app-traefik", "infra-mysql"],
  "required_inputs": [
    { "name": "DOMAIN_HUMHUB", "description": "Domínio para o HumHub (ex: humhub.oriondesign.art.br)", "type": "text" },
