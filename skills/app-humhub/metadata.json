    { "name": "HUMHUB_ADMIN_EMAIL", "description": "Email do admin", "type": "text" },
    { "name": "HUMHUB_ADMIN_PASS", "description": "Senha do admin", "type": "password" },
    { "name": "SMTP_FROM_EMAIL", "description": "Email remetente", "type": "text" },
    { "name": "SMTP_USER", "description": "Usuário SMTP", "type": "text" },
    { "name": "SMTP_PASS", "description": "Senha SMTP", "type": "password" },
    { "name": "SMTP_HOST", "description": "Host SMTP", "type": "text" },
    { "name": "SMTP_PORT", "description": "Porta SMTP", "type": "text" }
