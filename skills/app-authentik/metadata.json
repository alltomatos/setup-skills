{
  "name": "app-authentik",
  "description": "Instala o Authentik (SSO/identity provider moderno) como Docker Swarm com 2 servi\u00e7os.",
  "depends_on": [
    "infra-bootstrap",
    "app-traefik",
    "infra-postgres",
    "infra-redis"
  ],
  "required_inputs": [
    {
      "name": "DOMAIN_AUTHENTIK",
      "description": "Dom\u00ednio (ex: sso.oriondesign.art.br)",
      "type": "text"
    },
    {
      "name": "AUTHENTIK_EMAIL",
      "description": "Email do admin inicial",
      "type": "text"
    },
    {
      "name": "AUTHENTIK_PASS",
      "description": "Senha do admin inicial",
      "type": "password"
    }
  ],
  "persistence_path": "/root/dados_vps/app-authentik.md",
  "version": "1.0.0"
}
