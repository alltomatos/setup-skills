{
  "name": "app-passbolt",
  "description": "Instala o Passbolt (cofre de senhas open-source para equipes) como Docker Swarm.",
  "depends_on": [
    "infra-bootstrap",
    "app-traefik",
    "infra-mysql"
  ],
  "required_inputs": [
    {
      "name": "DOMAIN_PASSBOLT",
      "description": "Dom\u00ednio (ex: passwords.oriondesign.art.br)",
      "type": "text"
    },
    {
      "name": "PASSBOLT_EMAIL",
      "description": "Email do primeiro usu\u00e1rio",
      "type": "text"
    },
    {
      "name": "SMTP_USER",
      "description": "Usu\u00e1rio SMTP",
      "type": "text"
    },
    {
      "name": "SMTP_PASS",
      "description": "Senha SMTP",
      "type": "password"
    },
    {
      "name": "SMTP_HOST",
      "description": "Host SMTP",
      "type": "text"
    },
    {
      "name": "SMTP_PORT",
      "description": "Porta SMTP",
      "type": "text"
    }
  ],
  "persistence_path": "/root/dados_vps/app-passbolt.md",
  "version": "1.0.0"
}
