{
  "name": "app-passbolt",
  "description": "Instala o Passbolt (cofre de senhas open-source para equipes) como Docker Swarm.",
  "depends_on": ["infra-bootstrap", "app-traefik", "infra-mysql", "infra-postgres"],
  "required_inputs": [
    { "name": "DOMAIN_PASSBOLT", "description": "Domínio (ex: passwords.oriondesign.art.br)", "type": "text" },
    { "name": "PASSBOLT_EMAIL", "description": "Email do primeiro usuário", "type": "text" },
    { "name": "SMTP_USER", "description": "Usuário SMTP", "type": "text" },
    { "name": "SMTP_PASS", "description": "Senha SMTP", "type": "password" },
    { "name": "SMTP_HOST", "description": "Host SMTP", "type": "text" },
    { "name": "SMTP_PORT", "description": "Porta SMTP", "type": "text" }
  ],
  "persistence_path": "/root/dados_vps/app-passbolt.md"
}